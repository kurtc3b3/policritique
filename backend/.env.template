# Copy to .env in this directory (never commit .env)
#
#   cp .env.template .env

# SQLite database path (default: backend/data/policritique.db)
DB_PATH=

# UK Parliament Members API
MEMBERS_API_BASE_URL=https://members-api.parliament.uk

# Legacy MNIS API (contacts / reference data)
PARLIAMENT_DATA_BASE_URL=http://data.parliament.uk/membersdataplatform

# Democracy Club Candidates API
DEMOCRACY_CLUB_API_BASE_URL=https://candidates.democracyclub.org.uk

# UK Parliament psephology CSV data (GitHub)
PSEPHOLOGY_BASE_URL=https://raw.githubusercontent.com/ukparliament/psephology/main/db/data

# Manifesto Project API (register at https://manifesto-project.wzb.eu)
MANIFESTO_PROJECT_API_KEY=
MANIFESTO_PROJECT_BASE_URL=https://manifesto-project.wzb.eu/api/v1
MANIFESTO_PROJECT_CORE_VERSION=MPDS2025a
MANIFESTO_PROJECT_METADATA_VERSION=2025-1

# API authentication (change SECRET_KEY in production)
SECRET_KEY=change-me-in-production
JWT_LIFETIME_SECONDS=3600
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:3000,http://127.0.0.1:3000,http://localhost:8000,http://127.0.0.1:8000
API_HOST=127.0.0.1
API_PORT=8000
API_RELOAD=false
